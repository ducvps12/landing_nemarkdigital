                                <Link
                                    href="/solutions/startup"
                                    className="text-sm font-medium text-slate-700 hover:text-primary transition-colors block py-1.5 pl-3"
                                    onClick={() => setMobileMenuOpen(false)}
                                >
                                    Giải pháp cho startup
                                </Link>
                                <Link
                                    href="/solutions/online-sales"
                                    className="text-sm font-medium text-slate-700 hover:text-primary transition-colors block py-1.5 pl-3"
                                    onClick={() => setMobileMenuOpen(false)}
                                >
