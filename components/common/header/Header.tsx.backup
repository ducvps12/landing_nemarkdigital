                                <ul className="space-y-2">
                                    <li><Link href="/solutions/sme" className="block text-sm text-slate-300 hover:text-primary hover:underline font-bold">Giải pháp cho doanh nghiệp nhỏ & SME</Link></li>
                                    <li><Link href="/solutions/startup" className="block text-sm text-slate-300 hover:text-primary hover:underline font-bold">Giải pháp cho startup</Link></li>
                                    <li><Link href="/solutions/online-sales" className="block text-sm text-slate-300 hover:text-primary hover:underline font-bold">Giải pháp bán hàng online</Link></li>
                                    <li><Link href="/solutions/digital-conversion" className="block text-sm text-slate-300 hover:text-primary hover:underline font-bold">Giải pháp chuyển đổi số</Link></li>
                                    <li><Link href="/solutions/digital-branding" className="block text-sm text-slate-300 hover:text-primary hover:underline font-bold">Giải pháp xây dựng thương hiệu số</Link></li>
