                            </div>

                            <div className="border-t border-slate-200 pt-2">
                                <p className="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Giải pháp Website & Hệ thống</p>
                                <Link
                                    href="/services/update-optimization"
                                    className="text-sm font-medium text-slate-700 hover:text-primary transition-colors block py-1.5 pl-3"
                                    onClick={() => setMobileMenuOpen(false)}
                                >
                                    Nâng cấp & tối ưu website
                                </Link>
                                <Link
                                    href="/services/website-maintenance"
