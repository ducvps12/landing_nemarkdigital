                                >
                                    Tăng tốc & bảo mật website
                                </Link>
                                <Link
                                    href="/services/api-integration"
                                    className="text-sm font-medium text-slate-700 hover:text-primary transition-colors block py-1.5 pl-3"
                                    onClick={() => setMobileMenuOpen(false)}
                                >
                                    Tích hợp thanh toán, API, CRM
                                </Link>
                            </div>

                            <div className="border-t border-slate-200 pt-2">
                                <p className="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Dịch vụ SEO & Marketing số</p>
                                <Link
                                    href="/services/seo"
