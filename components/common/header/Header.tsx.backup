                                    onClick={() => setMobileMenuOpen(false)}
                                >
                                    SEO tổng thể website
                                </Link>
                            </div>

                            <div className="border-t border-slate-200 pt-2">
                                <p className="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Hạ tầng & Tài khoản số</p>
                                <Link
                                    href="/services/domain-hosting"
                                    className="text-sm font-medium text-slate-700 hover:text-primary transition-colors block py-1.5 pl-3"
                                    onClick={() => setMobileMenuOpen(false)}
                                >
                                    Domain & Hosting
                                </Link>
                                <Link
                                    href="/services/business-email"
                                    className="text-sm font-medium text-slate-700 hover:text-primary transition-colors block py-1.5 pl-3"
                                    onClick={() => setMobileMenuOpen(false)}
                                >
                                    Email doanh nghiệp
                                </Link>
                                <Link
                                    href="/services/vps"
                                    className="text-sm font-medium text-slate-700 hover:text-primary transition-colors block py-1.5 pl-3"
                                    onClick={() => setMobileMenuOpen(false)}
                                >
                                    VPS (Virtual Private Server)
                                </Link>
                                <Link
                                    href="/services/proxy"
                                    className="text-sm font-medium text-slate-700 hover:text-primary transition-colors block py-1.5 pl-3"
                                    onClick={() => setMobileMenuOpen(false)}
                                >
                                    Proxy / IP Proxy
                                </Link>
                            </div>

                            {/* Giải pháp cho Startup Section */}
                            <div className="border-t border-slate-200 pt-2">
                                <p className="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Giải pháp cho Startup</p>
                                <Link
                                    href="/solutions/sme"
                                    className="text-sm font-medium text-slate-700 hover:text-primary transition-colors block py-1.5 pl-3"
                                    onClick={() => setMobileMenuOpen(false)}
                                >
