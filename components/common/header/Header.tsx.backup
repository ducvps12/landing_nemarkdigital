                            <div className="border-t border-slate-200 pt-2">
                                <p className="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Thiết kế Web App</p>
                                <Link
                                    href="/dich-vu/thiet-ke-website"
                                    className="text-sm font-medium text-slate-700 hover:text-primary transition-colors block py-1.5 pl-3"
                                    onClick={() => setMobileMenuOpen(false)}
                                >
                                    Thiết kế Website
                                </Link>
                                <Link
                                    href="/services/app-design"
                                    className="text-sm font-medium text-slate-700 hover:text-primary transition-colors block py-1.5 pl-3"
