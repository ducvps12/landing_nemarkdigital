                                <span>Dịch vụ</span>
                                <span className="material-icons-outlined text-base ml-1">expand_more</span>
                            </button>
                            <div className={`absolute left-1/2 -translate-x-1/2 top-full mt-0 w-[720px] bg-slate-800 rounded-xl shadow-xl border border-slate-700 p-6 transition-all duration-200 origin-top ${showServicesMenu ? 'opacity-100 translate-y-0 visible' : 'opacity-0 translate-y-2 invisible'
                                }`}>
                                <div className="grid grid-cols-2 gap-6">
                                    <div>
                                        <h4 className="font-display font-bold text-white mb-3 text-sm uppercase tracking-wider">Dịch vụ</h4>
                                        <ul className="space-y-2">
                                            <li><Link href="#" className="block text-base text-white hover:text-primary hover:underline font-bold">Thiết kế Web App</Link></li>
                                            <li><Link href="/dich-vu/thiet-ke-website" className="block text-sm text-slate-300 hover:text-primary hover:underline">Thiết kế Website</Link></li>
                                            <li><Link href="/services/app-design" className="block text-sm text-slate-300 hover:text-primary hover:underline">Thiết kế App</Link></li>
                                            <li><Link href="#" className="block text-base text-white hover:text-primary hover:underline font-bold">Giải pháp Website & Hệ thống</Link></li>
                                            <li><Link href="/services/update-optimization" className="block text-sm text-slate-300 hover:text-primary hover:underline">Nâng cấp & tối ưu website</Link></li>
                                            <li><Link href="/services/website-maintenance" className="block text-sm text-slate-300 hover:text-primary hover:underline">Bảo trì – vận hành website</Link></li>
                                            <li><Link href="/services/website-operation" className="block text-sm text-slate-300 hover:text-primary hover:underline">Tăng tốc & bảo mật website</Link></li>
                                            <li><Link href="/services/api-integration" className="block text-sm text-slate-300 hover:text-primary hover:underline">Tích hợp thanh toán, API, CRM</Link></li>
                                        </ul>
                                    </div>
                                    <div>
                                        <ul className="space-y-2">
                                            <li><Link href="#" className="block text-base text-white hover:text-primary hover:underline font-bold">Dịch vụ SEO & Marketing số</Link></li>
                                            <li><Link href="/services/seo" className="block text-sm text-slate-300 hover:text-primary hover:underline">SEO tổng thể website</Link></li>
                                            <li><Link href="#" className="block text-sm text-slate-300 hover:text-primary hover:underline">Audit & tư vấn SEO</Link></li>
                                            <li><Link href="#" className="block text-base text-white hover:text-primary hover:underline font-bold">Hạ tầng & Tài khoản số</Link></li>
                                            <li><Link href="/services/domain-hosting" className="block text-sm text-slate-300 hover:text-primary hover:underline">Domain & Hosting</Link></li>
                                            <li><Link href="/services/business-email" className="block text-sm text-slate-300 hover:text-primary hover:underline">Email doanh nghiệp</Link></li>
                                            <li><Link href="/services/vps" className="block text-sm text-slate-300 hover:text-primary hover:underline">VPS (Virtual Private Server)</Link></li>
                                            <li><Link href="/services/proxy" className="block text-sm text-slate-300 hover:text-primary hover:underline">Proxy / IP Proxy</Link></li>
                                            <li><Link href="#" className="block text-sm text-slate-300 hover:text-primary hover:underline">Quản lý – vận hành hạ tầng</Link></li>
                                            <li><Link href="#" className="block text-sm text-slate-300 hover:text-primary hover:underline">Cấu hình – bảo mật hệ thống</Link></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {/* Startup Solutions Menu */}
                        <div
