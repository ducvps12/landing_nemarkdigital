# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# build logs & temp files
*.log
build-log*.txt
build-output.txt

# batch scripts
*.bat

# archives
*.zip
*.tar.gz
*.rar

# Docker (not used in production)
Dockerfile
docker-compose.yml
.dockerignore

# server config (managed on server)
nginx.conf
.htaccess

# lock files (using package-lock.json only)
yarn.lock

# temp directories
/temp_gen/
/temp_bare_repo/
/query

_deploy_staging/
deploy.zip
